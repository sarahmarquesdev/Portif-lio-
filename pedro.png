.item_menu a{
    color: var(--azul_escuro);
}

#body_ler_online {
    background-color: #efefef;
    padding: 16;
}

#segura_conteudo_lo {
    display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    margin: 6rem;
    justify-content: center;
    align-items: center;
}

#capa_sinopse {
    width: 70%;
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    margin: 0 0 6rem 0;
}

#capa {
    display: flex;
    align-items: center;
    justify-content: center;
}

#capa img {
    height: 30rem;
    border-radius: 1rem;
}

#texto {
    display: flex;
    flex-direction: column;
    margin: 0 4rem;
    text-align: justify;
}

#texto h2 {
    font-size: 4rem;
    font-weight: 500;
    color: var(--azul_escuro);
    margin-bottom: 2rem;
}

#texto p, #texto p a {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
}

#texto p a {
    text-decoration: none;
    color: var(--azul_padrao);
    font-weight: 600;
}

#texto p a:hover {
    text-decoration: underline;
    color: var(--azul_escuro);
}

#lista {
    display: flex;
    flex-direction: column;
    width: 70%;
    background-color: #FFFFFF;
    border-radius: 1rem;
    padding: 2rem;
}

#lista h3 {
    font-size: 3rem;
    font-weight: 400;
    color: var(--azul_escuro);
    margin: 1rem 0;
}

#lista ul {
    list-style: none;
}

#lista ul a {
    text-decoration: none;
}

#lista ul a li {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    color: var(--azul_escuro);
    margin: 1rem 0;
}

#lista ul a li:hover {
    color: var(--azul_padrao);
}

footer {
    margin-top: 1rem;
}

footer p {
    font-weight: bold;
    padding: 1rem;
    color: var(--azul_escuro);
}


@media screen and (max-width: 800px) { 
    /*---------------------
    - Menu Talet
    ---------------------*/
    #myLinks nav {
        background-color: var(--azul_padrao);
    }


    .item_menu a:hover{
        color: var(--amarelo_padrao);
    }
    
    #segura_conteudo_lo {
        margin: 6rem 0;
    }

    #capa_sinopse {
        width: 100%;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    #capa {
        margin: 0 0 3rem 0;
    }

    #segura_conteudo_lo div h2{
        text-align: center;
    }

    #lista {
        width: 80%;
    }
    
}