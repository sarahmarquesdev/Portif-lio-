.item_menu a {
    color: #000;
}
.item_menu a{
    color: var(--azul_escuro);
}

body {
    background-color: #efefef;
}

main {
    width: 90%;
    margin: 0 auto;
}

#titulo {
    text-align: center;
    padding: 3rem;
    color: var(--azul_escuro);   
}

#titulo h1 {
    font-weight: 300;
}

.img {
    margin-top: 9rem;
    width: 100%;
    
}

.aviso p {
    font-weight: bold;
}

.aviso ul li span {
    color: rgb(246, 250, 0);
    font-family: 'Montserrat', sans-serif;
    font-weight: bold;
}

footer {
    margin-top: 1rem;
}

footer p {
    font-weight: bold;
    padding: 1rem;
    color: var(--azul_escuro);
}

.passos .mob{
    display: none;
}

.passos .desk{
    display: flex;
}

.aviso {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
}

@media screen and (min-width: 800px) { 
    .passos {
        display: flex;
        flex-direction: column;
        margin: 1rem 0 4rem 0;
    }
    
     .passos h2, ul {
        font-weight: 300;
        font-size: 2.9rem;
        text-align: left;
        padding-left: 5%;
    }
    
    .passos ul, .aviso ul, .aviso p {
        padding-left: 6.5%;
        font-size: 1.9rem;
        display: flex;
        flex-wrap: wrap;
        flex-direction: column;
        align-items: baseline;
    }
    
    .passos ul li, .aviso ul li, .aviso p {
        margin-top: 1rem;
        font-family: 'Montserrat', sans-serif;
        font-weight: 400;
    }
    
    .aviso h3 {
        font-weight: 300;
        font-size: 3rem;
        color: var(--azul_padrao);
        padding-left: 5%;
    }

    .aviso p {
        padding-left: 5%;
    }
}

@media screen and (max-width: 800px) { 
    /*---------------------
    - Menu Talet
    ---------------------*/
    #myLinks nav {
        background-color: var(--azul_padrao);
    }
    
    .passos h2, ul {
        font-weight: 300;
        font-size: 2.9rem;
        padding-left: 5%;
    }
    
    .passos ul, .aviso ul, .aviso p {
        padding-left: 9%;
        font-size: 1.5rem;
        flex-direction: column;
        align-items: baseline;
    }
    
    .passos ul li, .aviso ul li, .aviso p {
        margin-top: 1rem;
        font-family: 'Montserrat', sans-serif;
        font-weight: 400;
    }

    .aviso h3 {
        font-weight: 300;
        font-size: 3rem;
        color: var(--azul_padrao);
        padding-left: 5%;
    }

    .aviso p {
        padding-left: 5%;
    }
}